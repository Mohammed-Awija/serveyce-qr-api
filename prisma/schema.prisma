generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrganizationKind {
  HOTEL
  HOSTEL
  SHORT_TERM_RENTAL
  RESTAURANT
  CAFE
  BAR
  OTHER
}

enum LocationKind {
  ROOM
  TABLE
  AREA
  OTHER
}

enum MembershipRole {
  OWNER
  STAFF
}

enum RequestStatus {
  PENDING
  ACCEPTED
  IN_PROGRESS
  DONE
  CANCELLED
}

enum OfferingNodeType {
  CATEGORY
  ITEM
}

enum ModifierSelectionType {
  SINGLE
  MULTIPLE
}

model Organization {
  id                String             @id @default(uuid())
  slug              String             @unique
  name              String
  kind              OrganizationKind   @default(HOTEL)
  address           String?
  defaultLanguage   String             @default("en")
  timezone          String             @default("Europe/Istanbul")
  memberships       Membership[]
  locations         Location[]
  offeringNodes     OfferingNode[]
  modifierGroups    ModifierGroup[]
  modifierOptions   ModifierOption[]
  requests          Request[]
  locationOfferings LocationOffering[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model Location {
  id             String             @id @default(uuid())
  organizationId String
  kind           LocationKind       @default(ROOM)
  name           String
  displayName    String?
  notes          String?
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  requests       Request[]
  offerings      LocationOffering[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([organizationId])
}

model OfferingNode {
  id             String           @id @default(uuid())
  organizationId String
  parentId       String?
  name           String
  type           OfferingNodeType @default(ITEM)
  icon           String           @default("bell")
  enabled        Boolean          @default(true)
  displayOrder   Int              @default(0)

  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent         OfferingNode?      @relation("NodeChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children       OfferingNode[]     @relation("NodeChildren")
  modifierGroups ModifierGroup[]
  requests       Request[]
  locationLinks  LocationOffering[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([parentId])
}

model LocationOffering {
  id             String @id @default(uuid())
  organizationId String
  locationId     String
  offeringNodeId String

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  location     Location     @relation(fields: [locationId], references: [id], onDelete: Cascade)
  offeringNode OfferingNode @relation(fields: [offeringNodeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([locationId, offeringNodeId])
  @@index([organizationId])
  @@index([locationId])
}

model ModifierGroup {
  id             String                @id @default(uuid())
  organizationId String
  offeringNodeId String
  name           String
  selectionType  ModifierSelectionType @default(SINGLE)
  required       Boolean               @default(false)
  displayOrder   Int                   @default(0)

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  offeringNode OfferingNode     @relation(fields: [offeringNodeId], references: [id], onDelete: Cascade)
  options      ModifierOption[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([offeringNodeId])
}

model ModifierOption {
  id              String @id @default(uuid())
  organizationId  String
  modifierGroupId String
  name            String
  displayOrder    Int    @default(0)

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  modifierGroup ModifierGroup @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([modifierGroupId])
}

model User {
  id          String       @id @default(uuid())
  clerkId     String       @unique
  email       String
  firstName   String?
  lastName    String?
  memberships Membership[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Membership {
  id             String         @id @default(uuid())
  userId         String
  organizationId String
  role           MembershipRole @default(OWNER)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime       @default(now())

  @@unique([userId, organizationId])
}

model Request {
  id              String        @id @default(uuid())
  organizationId  String
  locationId      String
  offeringNodeId  String? // the tree item ordered
  itemName        String? // snapshot of the item name at order time
  selections      Json? // snapshot of chosen modifiers
  status          RequestStatus @default(PENDING)
  guestName       String?
  notes           String?
  assignedStaffId String?
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  location        Location      @relation(fields: [locationId], references: [id], onDelete: Cascade)
  offeringNode    OfferingNode? @relation(fields: [offeringNodeId], references: [id], onDelete: SetNull)
  createdAt       DateTime      @default(now())
  acceptedAt      DateTime?
  completedAt     DateTime?

  @@index([organizationId])
  @@index([status])
}
